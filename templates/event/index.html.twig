{% extends 'base.html.twig' %}
{% block title %}Événements — EventBook{% endblock %}
{% block body %}
<h2 class="mb-4"><i class="bi bi-calendar-event me-2 text-primary"></i>Événements à venir</h2>
<div class="row g-4">
    {% for event in events %}
    <div class="col-md-4">
        <div class="card h-100">
            {% if event.image %}
                <img src="/uploads/{{ event.image }}" class="card-img-top" style="height:200px;object-fit:cover" alt="">
            {% else %}
                <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:200px">
                    <i class="bi bi-calendar-event text-primary" style="font-size:3rem"></i>
                </div>
            {% endif %}
            <div class="card-body">
                <h5 class="card-title">{{ event.title }}</h5>
                <p class="text-muted small">
                    <i class="bi bi-calendar3 me-1"></i>{{ event.date|date('d/m/Y à H:i') }}<br>
                    <i class="bi bi-geo-alt me-1"></i>{{ event.location }}<br>
                    <i class="bi bi-people me-1"></i>{{ event.availableSeats }} places disponibles
                </p>
                <p class="card-text small">{{ event.description|slice(0, 100) }}...</p>
            </div>
            <div class="card-footer bg-transparent">
                <a href="{{ path('app_events_show', {id: event.id}) }}" class="btn btn-outline-primary btn-sm w-100">
                    Voir détails
                </a>
            </div>
        </div>
    </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucun événement disponible pour le moment.</div>
        </div>
    {% endfor %}
</div>
{% endblock %}