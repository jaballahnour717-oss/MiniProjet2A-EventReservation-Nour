<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin — EventBook{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f1f5f9; }

        .sidebar {
            width: 240px;
            min-height: 100vh;
            background: #1e293b;
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            overflow-y: auto;
        }
        .sidebar-brand {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-brand a {
            color: #fff;
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 700;
        }
        .sidebar-brand span {
            color: #64748b;
            font-size: .75rem;
            display: block;
            margin-top: 2px;
        }
        .sidebar-nav { padding: .75rem 0; }
        .nav-section {
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: #475569;
            padding: .75rem 1.5rem .25rem;
        }
        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .55rem 1.5rem;
            color: #94a3b8;
            text-decoration: none;
            font-size: .875rem;
            border-left: 2px solid transparent;
            transition: all .12s;
        }
        .sidebar-nav a:hover,
        .sidebar-nav a.active {
            background: rgba(255,255,255,.06);
            color: #fff;
            border-left-color: #3b82f6;
        }
        .sidebar-nav a i { width: 16px; text-align: center; }

        .main-content { margin-left: 240px; }
        .topbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: .75rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 50;
        }
        .topbar h5 { margin: 0; font-size: .95rem; font-weight: 600; }
        .page-content { padding: 1.5rem; }

        .stat-card {
            background: #fff;
            border-radius: .75rem;
            padding: 1.25rem 1.5rem;
            border-left: 4px solid var(--accent, #3b82f6);
        }
        .stat-card .label { font-size: .8rem; color: #64748b; margin-bottom: .25rem; }
        .stat-card .value { font-size: 1.75rem; font-weight: 700; }

        .card { border: none; box-shadow: 0 1px 6px rgba(0,0,0,.06); }
        .table th {
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #64748b;
            font-weight: 600;
            background: #f8fafc;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ── SIDEBAR ── #}
<aside class="sidebar">
    <div class="sidebar-brand">
        <a href="{{ path('admin_dashboard') }}">
            <i class="bi bi-calendar-event-fill me-2"></i>EventBook
        </a>
        <span>Administration</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section">Principal</div>
        <a href="{{ path('admin_dashboard') }}"
           class="{{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
            <i class="bi bi-speedometer2"></i> Tableau de bord
        </a>

        <div class="nav-section">Gestion</div>
        <a href="{{ path('admin_events_index') }}"
           class="{{ app.request.attributes.get('_route') starts with 'admin_events' ? 'active' : '' }}">
            <i class="bi bi-calendar3"></i> Événements
        </a>
        <a href="{{ path('admin_reservations_index') }}"
           class="{{ app.request.attributes.get('_route') starts with 'admin_reservations' ? 'active' : '' }}">
            <i class="bi bi-ticket-perforated"></i> Réservations
        </a>

        <div class="nav-section">Compte</div>
        <a href="{{ path('api_events_list') }}">
            <i class="bi bi-globe"></i> Voir le site
        </a>
        <a href="{{ path('admin_logout') }}" class="text-danger-emphasis">
            <i class="bi bi-box-arrow-right"></i> Déconnexion
        </a>
    </nav>
</aside>

{# ── MAIN ── #}
<div class="main-content">
    <div class="topbar">
        <h5>{% block page_title %}Dashboard{% endblock %}</h5>
        <span class="text-muted small">
            <i class="bi bi-person-circle me-1"></i>{{ app.user.userIdentifier }}
        </span>
    </div>

    <div class="page-content">
        {# Flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
